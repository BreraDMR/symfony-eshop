{% extends 'base.html.twig' %}

{% block title %}Payment — Beans &amp; Leaves{% endblock %}

{% block body %}
    <div class="payment-box">
        <h1>Simulated payment</h1>
        <p class="text-muted">
            This is a stand-in for a hosted payment page. With the Stripe gateway
            enabled the customer would be redirected to Stripe Checkout instead.
        </p>

        <p>Order <strong>{{ order.reference }}</strong></p>
        <p class="price">{{ order.total|money }}</p>

        <div class="payment-actions">
            <form method="post" action="{{ path('app_checkout_confirm', { reference: order.reference }) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('checkout_confirm_' ~ order.reference) }}">
                <button type="submit" class="btn">Pay now</button>
            </form>
            <a class="btn btn-secondary" href="{{ path('app_checkout_cancel', { reference: order.reference }) }}">Cancel</a>
        </div>
    </div>
{% endblock %}
