{% extends 'base.html.twig' %}

{% block title %}Admin login — Beans &amp; Leaves{% endblock %}

{% block body %}
    <div class="payment-box" style="max-width:420px">
        <h1>Admin login</h1>

        {% if error %}
            <div class="flash flash-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form method="post" class="checkout-form">
            <label for="inputEmail">Email</label>
            <input type="email" value="{{ last_username }}" name="_username" id="inputEmail" autocomplete="email" required autofocus>

            <label for="inputPassword">Password</label>
            <input type="password" name="_password" id="inputPassword" autocomplete="current-password" required>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="btn">Sign in</button>
        </form>
    </div>
{% endblock %}
