{% extends 'admin/base.html.twig' %}

{% block title %}Order {{ order.reference }} — Admin{% endblock %}

{% block admin_body %}
    <p><a href="{{ path('app_admin_order_index') }}">&larr; Back to orders</a></p>

    <h1>Order {{ order.reference }}</h1>
    <p>
        <span class="badge badge-{{ order.status.value }}">{{ order.status.label }}</span>
        placed {{ order.createdAt|date('d.m.Y H:i') }}
    </p>

    <div class="order-detail-grid">
        <div>
            <h2>Customer</h2>
            <p>
                {{ order.customerName }}<br>
                {{ order.customerEmail }}
            </p>
            <h2>Shipping address</h2>
            <p>{{ order.shippingAddress|nl2br }}</p>
        </div>

        <div>
            <h2>Update status</h2>
            <form method="post" action="{{ path('app_admin_order_status', { id: order.id }) }}" class="checkout-form">
                <input type="hidden" name="_token" value="{{ csrf_token('order_status_' ~ order.id) }}">
                <select name="status">
                    {% for status in statuses %}
                        <option value="{{ status.value }}" {{ status == order.status ? 'selected' }}>{{ status.label }}</option>
                    {% endfor %}
                </select>
                <button type="submit" class="btn">Update</button>
            </form>
            {% if order.paymentReference %}
                <p class="text-muted">Payment reference: {{ order.paymentReference }}</p>
            {% endif %}
        </div>
    </div>

    <h2>Items</h2>
    <table class="table">
        <thead>
            <tr><th>Product</th><th>Unit price</th><th>Qty</th><th>Subtotal</th></tr>
        </thead>
        <tbody>
            {% for item in order.items %}
                <tr>
                    <td>{{ item.productName }}</td>
                    <td>{{ item.unitPrice|money }}</td>
                    <td>{{ item.quantity }}</td>
                    <td>{{ item.subtotal|money }}</td>
                </tr>
            {% endfor %}
        </tbody>
        <tfoot>
            <tr><th colspan="3" style="text-align:right">Total</th><th>{{ order.total|money }}</th></tr>
        </tfoot>
    </table>
{% endblock %}
