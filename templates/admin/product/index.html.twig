{% extends 'admin/base.html.twig' %}

{% block title %}Products — Admin{% endblock %}

{% block admin_body %}
    <div class="admin-header">
        <h1>Products</h1>
        <a class="btn" href="{{ path('app_admin_product_new') }}">New product</a>
    </div>

    <table class="table">
        <thead>
            <tr><th>Name</th><th>Category</th><th>Price</th><th>Stock</th><th>Active</th><th></th></tr>
        </thead>
        <tbody>
            {% for product in products %}
                <tr>
                    <td>{{ product.name }}</td>
                    <td>{{ product.category.name }}</td>
                    <td>{{ product.price|money }}</td>
                    <td>{{ product.stock }}</td>
                    <td>{{ product.active ? 'Yes' : 'No' }}</td>
                    <td class="row-actions">
                        <a href="{{ path('app_admin_product_edit', { id: product.id }) }}">Edit</a>
                        <form method="post" action="{{ path('app_admin_product_delete', { id: product.id }) }}"
                              onsubmit="return confirm('Delete this product?');" class="inline-form">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_product_' ~ product.id) }}">
                            <button type="submit" class="link-button">Delete</button>
                        </form>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}
