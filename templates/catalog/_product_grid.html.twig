<div class="product-grid">
    {% for product in products %}
        <div class="product-card">
            <a class="product-thumb" href="{{ path('app_catalog_product', { slug: product.slug }) }}">
                {% if product.imageFilename %}
                    <img src="{{ asset('images/products/' ~ product.imageFilename) }}" alt="{{ product.name }}" loading="lazy">
                {% else %}
                    <span class="product-thumb-placeholder">☕</span>
                {% endif %}
            </a>
            <h3><a href="{{ path('app_catalog_product', { slug: product.slug }) }}">{{ product.name }}</a></h3>
            <span class="muted">{{ product.category.name }}</span>
            <span class="price">{{ product.price|money }}</span>
            {% if product.inStock %}
                <a class="btn" href="{{ path('app_catalog_product', { slug: product.slug }) }}">View</a>
            {% else %}
                <span class="out-of-stock">Out of stock</span>
            {% endif %}
        </div>
    {% endfor %}
</div>
