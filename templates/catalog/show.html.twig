{% extends 'base.html.twig' %}

{% block title %}{{ product.name }} — Beans &amp; Leaves{% endblock %}

{% block body %}
    <p><a class="back-link" href="{{ path('app_catalog_index') }}"><span class="back-arrow" aria-hidden="true">&larr;</span> Back to shop</a></p>

    <div class="product-detail">
        {% if product.imageFilename %}
            <img class="product-detail-image" src="{{ asset('images/products/' ~ product.imageFilename) }}" alt="{{ product.name }}">
        {% endif %}
        <span class="muted text-muted">{{ product.category.name }}</span>
        <h1>{{ product.name }}</h1>
        <span class="price">{{ product.price|money }}</span>

        {% if product.description %}
            <p>{{ product.description }}</p>
        {% endif %}

        {% if product.inStock %}
            <p class="text-muted">{{ product.stock }} in stock</p>
            <form method="post" action="{{ path('app_cart_add', { id: product.id }) }}" class="add-to-cart">
                <input type="hidden" name="_token" value="{{ csrf_token('cart_add_' ~ product.id) }}">
                <input type="number" name="quantity" value="1" min="1" max="{{ product.stock }}" class="qty-input">
                <button type="submit" class="btn">Add to cart</button>
            </form>
        {% else %}
            <p class="out-of-stock">Currently out of stock</p>
        {% endif %}
    </div>
{% endblock %}
