{% extends 'base.html.twig' %}

{% block title %}Shop — Beans &amp; Leaves{% endblock %}

{% block body %}
    <h1>Our coffee &amp; tea</h1>

    <div class="category-filter">
        <a href="{{ path('app_catalog_index') }}" class="{{ activeCategory is null ? 'active' }}">All</a>
        {% for category in categories %}
            <a href="{{ path('app_catalog_index', { category: category.slug }) }}"
               class="{{ activeCategory and activeCategory.slug == category.slug ? 'active' }}">
                {{ category.name }}
            </a>
        {% endfor %}
    </div>

    {% if products is empty %}
        <p class="text-muted">No products in this category yet.</p>
    {% else %}
        <div class="product-grid">
            {% for product in products %}
                <div class="product-card">
                    <h3><a href="{{ path('app_catalog_product', { slug: product.slug }) }}">{{ product.name }}</a></h3>
                    <span class="muted">{{ product.category.name }}</span>
                    <span class="price">{{ product.price|money }}</span>
                    {% if product.inStock %}
                        <a class="btn" href="{{ path('app_catalog_product', { slug: product.slug }) }}">View</a>
                    {% else %}
                        <span class="out-of-stock">Out of stock</span>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
