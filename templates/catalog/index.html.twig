{% extends 'base.html.twig' %}

{% block title %}Shop — Beans &amp; Leaves{% endblock %}

{% block body %}
    <h1>Our coffee &amp; tea</h1>

    <form class="search-form" method="get" action="{{ path('app_catalog_search') }}" role="search">
        <input type="search" name="q" placeholder="Search products…" aria-label="Search products">
        <button class="btn" type="submit">Search</button>
    </form>

    <div class="category-filter">
        <a href="{{ path('app_catalog_index') }}" class="{{ activeCategory is null ? 'active' }}">All</a>
        {% for category in categories %}
            <a href="{{ path('app_catalog_index', { category: category.slug }) }}"
               class="{{ activeCategory and activeCategory.slug == category.slug ? 'active' }}">
                {{ category.name }}
            </a>
        {% endfor %}
    </div>

    {% if products is empty %}
        <p class="text-muted">No products in this category yet.</p>
    {% else %}
        {{ include('catalog/_product_grid.html.twig') }}
    {% endif %}
{% endblock %}
