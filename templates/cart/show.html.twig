{% extends 'base.html.twig' %}

{% block title %}Your cart — Beans &amp; Leaves{% endblock %}

{% block body %}
    <h1>Your cart</h1>

    {% if cart.empty %}
        <p class="text-muted">Your cart is empty.</p>
        <p><a class="btn" href="{{ path('app_catalog_index') }}">Browse the shop</a></p>
    {% else %}
        <table class="table cart-table">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Subtotal</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for item in cart.items %}
                    <tr>
                        <td data-label="Product">
                            <a href="{{ path('app_catalog_product', { slug: item.product.slug }) }}">
                                {{ item.product.name }}
                            </a>
                        </td>
                        <td data-label="Price">{{ item.product.price|money }}</td>
                        <td data-label="Quantity">
                            <form method="post" action="{{ path('app_cart_update', { id: item.product.id }) }}" class="inline-form js-cart-update">
                                <input type="hidden" name="_token" value="{{ csrf_token('cart_update_' ~ item.product.id) }}">
                                <input type="number" name="quantity" value="{{ item.quantity }}" min="1" max="{{ item.product.stock }}" class="qty-input">
                                {# Only shown when JavaScript is off; otherwise the quantity auto-updates. #}
                                <noscript><button type="submit" class="btn btn-secondary">Update</button></noscript>
                            </form>
                        </td>
                        <td data-label="Subtotal" data-cart-subtotal>{{ item.subtotal|money }}</td>
                        <td data-label="">
                            <form method="post" action="{{ path('app_cart_remove', { id: item.product.id }) }}" class="inline-form js-cart-remove">
                                <input type="hidden" name="_token" value="{{ csrf_token('cart_remove_' ~ item.product.id) }}">
                                <button type="submit" class="btn btn-secondary">Remove</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="3" style="text-align:right">Total</th>
                    <th data-cart-total>{{ cart.total|money }}</th>
                    <th></th>
                </tr>
            </tfoot>
        </table>

        <div class="cart-actions">
            <a class="btn-secondary btn" href="{{ path('app_catalog_index') }}">Continue shopping</a>
            <a class="btn" href="{{ path('app_checkout_start') }}">Proceed to checkout</a>
        </div>
    {% endif %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {# Progressive enhancement: recompute totals in place on quantity change.
       Without JS the form + Update button above keep working. #}
    <script src="{{ asset('js/cart.js') }}" defer></script>
{% endblock %}
